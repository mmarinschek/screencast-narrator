{
  "recording": {
    "fps": 25,
    "jpegQuality": 80,
    "minFrames": 3,
    "minFrameWaitMs": 40,
    "stopSettleMs": 100,
    "codec": "libx264",
    "preset": "fast",
    "crf": 18,
    "pixelFormat": "yuv420p"
  },
  "highlight": {
    "scrollWaitMs": 1000,
    "drawWaitMs": 200,
    "removeWaitMs": 200,
    "color": "#fb7185",
    "padding": 18,
    "animationSpeedMs": 600,
    "lineWidthMin": 2,
    "lineWidthMax": 8,
    "opacity": 0.65,
    "segments": 200,
    "coverage": 0.93,
    "scrollJs": "js/highlight-scroll.js",
    "scrollWaitJs": "js/highlight-scroll-wait.js",
    "drawJs": "js/highlight-draw.js",
    "removeJs": "js/highlight-remove.js"
  }
}
